<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "ruby-on-rails-101" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ruby-on-rails-101">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'selector',
      }
      
      // On page load or when changing themes, best to add inline in `head` to avoid FOUC
      if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
      } else {
          document.documentElement.classList.remove('dark')
      }
    </script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 transition-colors duration-200 dark:bg-slate-900 dark:text-slate-100 min-h-screen">
    <nav class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 transition-colors shadow-sm sticky top-0 z-50" data-controller="navbar theme">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <!-- Logo / Brand -->
            <div class="flex-shrink-0 flex items-center">
              <%= link_to root_path, class: "flex items-center gap-2 group" do %>
                <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white shadow-blue-500/20 shadow-lg group-hover:scale-110 transition-transform">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                <span class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400">HRMS</span>
              <% end %>
            </div>
            <!-- Desktop Links -->
            <div class="hidden sm:ml-8 sm:flex sm:space-x-8">
              <% active_link_class = "border-blue-500 text-slate-900 dark:text-white inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-all" %>
              <% inactive_link_class = "border-transparent text-slate-500 dark:text-slate-400 hover:border-slate-300 dark:hover:border-slate-500 hover:text-slate-700 dark:hover:text-slate-200 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-all" %>
              
              <%= link_to "Employees", root_path, class: (current_page?(root_path) || controller_name == 'employee' ? active_link_class : inactive_link_class) %>
              <%= link_to "Attendances", attendances_path, class: (controller_name == 'attendances' ? active_link_class : inactive_link_class) %>
              <a href="#" class="<%= inactive_link_class %>">Settings</a>
            </div>
          </div>

          <!-- Right side: Theme, Profile, Mobile Menu -->
          <div class="hidden sm:ml-6 sm:flex sm:items-center space-x-4">
            <!-- Theme Toggle (Integrated) -->
            <button 
              type="button" 
              data-action="click->theme#toggle"
              class="text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 focus:outline-none focus:ring-4 focus:ring-slate-200 dark:focus:ring-slate-700 rounded-lg text-sm p-2.5 transition-all"
            >
              <svg data-theme-target="darkIcon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
              <svg data-theme-target="lightIcon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
            </button>

            <!-- Notifications (Optional mockup) -->
            <button class="p-2 text-slate-400 hover:text-slate-500 dark:hover:text-slate-300 transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
            </button>

            <!-- Admin Profile Dropdown -->
            <div class="relative ml-3">
              <button 
                type="button" 
                data-action="click->navbar#toggleProfileDropdown"
                class="flex items-center max-w-xs text-sm bg-white dark:bg-slate-800 rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 p-0.5 border border-slate-200 dark:border-slate-700 shadow-sm transition-all hover:scale-105"
              >
                <img class="w-8 h-8 rounded-full object-cover" src="https://ui-avatars.com/api/?name=Admin+User&background=0284c7&color=fff" alt="Profile">
                <span class="ml-2 pr-2 text-slate-700 dark:text-slate-200 font-medium text-xs hidden lg:inline">Admin User</span>
              </button>
              <!-- Dropdown menu -->
              <div 
                data-navbar-target="profileDropdown"
                class="hidden origin-top-right absolute right-0 mt-2 w-48 rounded-md shadow-lg py-1 bg-white dark:bg-slate-800 ring-1 ring-black ring-opacity-5 focus:outline-none border border-slate-100 dark:border-slate-700 z-50 animate-in fade-in slide-in-from-top-1 duration-200"
              >
                <a href="#" class="block px-4 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-700">Your Profile</a>
                <a href="#" class="block px-4 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-700">Settings</a>
                <div class="border-t border-slate-100 dark:border-slate-700 my-1"></div>
                <a href="#" class="block px-4 py-2 text-sm text-rose-600 dark:text-rose-400 hover:bg-slate-100 dark:hover:bg-slate-700">Sign out</a>
              </div>
            </div>
          </div>

          <!-- Hamburger menu button -->
          <div class="flex items-center sm:hidden">
            <button 
              type="button" 
              data-action="click->navbar#toggleMobileMenu"
              class="inline-flex items-center justify-center p-2 rounded-md text-slate-400 hover:text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700 focus:outline-none transition-all"
            >
              <svg class="h-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile menu -->
      <div 
        data-navbar-target="mobileMenu"
        class="hidden sm:hidden bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 animate-in slide-in-from-top duration-200"
      >
        <div class="pt-2 pb-3 space-y-1">
          <%= link_to "Employees", root_path, class: "bg-blue-50 dark:bg-blue-900/20 border-blue-500 text-blue-700 dark:text-blue-400 block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>
          <a href="#" class="border-transparent text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:border-slate-300 block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-all">Analytics</a>
          <a href="#" class="border-transparent text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:border-slate-300 block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-all">Settings</a>
        </div>
        <div class="pt-4 pb-3 border-t border-slate-200 dark:border-slate-700">
          <div class="flex items-center px-4">
            <div class="flex-shrink-0">
              <img class="h-10 w-10 rounded-full border border-slate-200 dark:border-slate-700" src="https://ui-avatars.com/api/?name=Admin+User&background=0284c7&color=fff" alt="Profile">
            </div>
            <div class="ml-3">
              <div class="text-base font-medium text-slate-800 dark:text-white">Admin User</div>
              <div class="text-sm font-medium text-slate-500 dark:text-slate-400">admin@teamtrain.com</div>
            </div>
            <button 
              type="button" 
              data-action="click->theme#toggle"
              class="ml-auto text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 transition-all p-2 rounded-lg"
            >
              <svg data-theme-target="darkIcon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
              <svg data-theme-target="lightIcon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
            </button>
          </div>
          <div class="mt-3 space-y-1">
            <a href="#" class="block px-4 py-2 text-base font-medium text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700">Your Profile</a>
            <a href="#" class="block px-4 py-2 text-base font-medium text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700">Settings</a>
            <a href="#" class="block px-4 py-2 text-base font-medium text-rose-600 dark:text-rose-400 hover:bg-slate-100 dark:hover:bg-slate-700">Sign out</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="container mx-auto pb-12">
      <%= yield %>
    </main>
  </body>
</html>
