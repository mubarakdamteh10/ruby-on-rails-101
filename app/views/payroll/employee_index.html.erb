<div class="min-h-screen bg-slate-50 dark:bg-slate-900 p-6 transition-colors duration-200">
  <div class="mx-auto max-w-5xl">
    <!-- Header -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight italic">My <span class="text-blue-600 dark:text-blue-400">Payroll</span> History</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-2 text-lg">
          View your monthly earnings and deductions
        </p>
      </div>
    </div>

    <% if @payrolls.any? %>
      <div class="space-y-6">
        <% @payrolls.each do |payroll| %>
          <div class="bg-white dark:bg-slate-800 rounded-3xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden group hover:shadow-md transition-all">
            <div class="p-8">
              <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                <div>
                  <div class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-1"><%= payroll.year %></div>
                  <h2 class="text-2xl font-black text-slate-900 dark:text-white"><%= Date::MONTHNAMES[payroll.month] %></h2>
                </div>
                
                <div class="flex flex-wrap gap-8 items-center">
                  <div class="text-right">
                    <div class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Net Pay</div>
                    <div class="text-3xl font-black text-blue-600 dark:text-blue-400">
                      <%= number_to_currency(payroll.net_amount, unit: "฿", format: "%n %u") %>
                    </div>
                  </div>
                  <div class="w-px h-12 bg-slate-100 dark:bg-slate-700 hidden md:block"></div>
                  <div class="bg-slate-50 dark:bg-slate-900/50 rounded-2xl p-4 flex gap-6">
                    <div class="text-center">
                      <div class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Days</div>
                      <div class="font-bold text-slate-900 dark:text-white"><%= payroll.total_worked_days %></div>
                    </div>
                    <div class="text-center">
                      <div class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">OT Hours</div>
                      <div class="font-bold text-slate-900 dark:text-white"><%= payroll.total_ot_hours.to_i %>h</div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="mt-8 pt-8 border-t border-slate-100 dark:border-slate-700 grid grid-cols-1 md:grid-cols-4 gap-6">
                <div>
                  <div class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">Base Salary</div>
                  <div class="font-bold text-slate-700 dark:text-slate-300"><%= number_to_currency(payroll.base_salary, unit: "฿", format: "%n %u") %></div>
                </div>
                <div>
                  <div class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">OT Payment</div>
                  <div class="font-bold text-emerald-600 dark:text-emerald-400">+ <%= number_to_currency(payroll.ot_payment, unit: "฿", format: "%n %u") %></div>
                </div>
                <div>
                  <div class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">Tax (<%= payroll.tax_percentage %>% )</div>
                  <div class="font-bold text-rose-600 dark:text-rose-400">- <%= number_to_currency(payroll.tax_amount, unit: "฿", format: "%n %u") %></div>
                </div>
                <div>
                  <div class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">Gross Income</div>
                  <div class="font-bold text-slate-900 dark:text-white"><%= number_to_currency(payroll.gross_salary, unit: "฿", format: "%n %u") %></div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] p-12 text-center border-2 border-dashed border-slate-200 dark:border-slate-700">
        <div class="w-20 h-20 bg-slate-50 dark:bg-slate-900 rounded-3xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">No Payroll Records Found</h3>
        <p class="text-slate-500 dark:text-slate-400">Your payroll records will appear here once they are processed by the administrator.</p>
      </div>
    <% end %>
  </div>
</div>
