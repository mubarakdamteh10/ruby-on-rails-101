<div class="min-h-screen bg-slate-50 dark:bg-slate-900 p-6 transition-colors duration-200">
  <div class="mx-auto max-w-4xl">
    <!-- Header/Back Navigation -->
    <div class="mb-10 flex flex-col sm:flex-row sm:items-center justify-between gap-6">
      <%= link_to attendances_path, class: "group flex items-center gap-3 text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-400 transition-all font-semibold" do %>
        <div class="w-10 h-10 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </div>
        <span>Back to List</span>
      <% end %>
      
      <div class="sm:text-right bg-white dark:bg-slate-800 px-6 py-3 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm">
        <h1 class="text-xl font-bold text-slate-900 dark:text-white"><%= @employee.name %></h1>
        <p class="text-sm font-medium text-blue-600 dark:text-blue-400"><%= @employee.position %> • <%= @employee.department %></p>
      </div>
    </div>

    <!-- Attendance Action Card -->
    <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] border border-slate-200 dark:border-slate-700 p-10 shadow-2xl transition-all mb-12 relative overflow-hidden text-center">
      <!-- Decorative background elements -->
      <div class="absolute -top-24 -right-24 w-80 h-80 bg-blue-500/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl"></div>
      
      <div class="relative flex flex-col items-center">
        <!-- Status Indicator -->
        <div class="mb-8 relative">
          <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white mb-2 shadow-2xl shadow-blue-500/30 animate-pulse-slow">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 rounded-full border-4 border-white dark:border-slate-800 flex items-center justify-center <%= @is_checked_in ? 'bg-emerald-500' : 'bg-slate-300' %>">
            <div class="w-2 h-2 rounded-full bg-white"></div>
          </div>
        </div>
        
        <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-3 tracking-tight">
          <%= @is_checked_in ? "You are Checked In" : "Not Checked In" %>
        </h2>
        
        <p class="text-slate-500 dark:text-slate-400 mb-10 max-w-sm text-lg leading-relaxed">
          <% if @is_checked_in %>
            Working since <span class="font-bold text-slate-900 dark:text-white"><%= @last_attendance.check_in.strftime('%H:%M %p') %></span>.<br>Don't forget to check out!
          <% else %>
            Start your workday by checking in. Your time will be recorded instantly.
          <% end %>
        </p>

        <% if @is_checked_in %>
          <%= button_to check_out_attendance_path(@employee), method: :patch, class: "group relative active:scale-95 transition-transform duration-100" do %>
            <div class="absolute -inset-2 bg-gradient-to-r from-rose-500 to-orange-500 rounded-3xl blur-lg opacity-40 group-hover:opacity-100 transition duration-500"></div>
            <div class="relative px-16 py-5 bg-rose-600 hover:bg-rose-700 rounded-2xl text-white font-black text-xl shadow-2xl flex items-center gap-4 transition-all border border-white/10">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-6 0v-1m6-10V7a3 3 0 00-6 0v1"></path></svg>
              <span>Check Out</span>
            </div>
          <% end %>
        <% else %>
          <%= button_to check_in_attendance_path(@employee), method: :post, class: "group relative active:scale-95 transition-transform duration-100" do %>
            <div class="absolute -inset-2 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-3xl blur-lg opacity-40 group-hover:opacity-100 transition duration-500"></div>
            <div class="relative px-16 py-5 bg-blue-600 hover:bg-blue-700 rounded-2xl text-white font-black text-xl shadow-2xl flex items-center gap-4 transition-all border border-white/10">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-6 0v-1m6-10V7a3 3 0 00-6 0v1"></path></svg>
              <span>Check In</span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Recent History -->
    <div class="bg-white dark:bg-slate-800 rounded-3xl border border-slate-200 dark:border-slate-700 overflow-hidden shadow-sm">
      <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-700 flex items-center justify-between">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white">Recent Activity</h3>
        <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Last 10 Events</span>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 dark:divide-slate-700">
          <thead class="bg-slate-50/50 dark:bg-slate-900/30">
            <tr>
              <th class="px-8 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Status</th>
              <th class="px-8 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Date</th>
              <th class="px-8 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">In</th>
              <th class="px-8 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Out</th>
              <th class="px-8 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Duration</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50 dark:divide-slate-700">
            <% if @attendances.any? %>
              <% @attendances.each do |attendance| %>
                <tr class="hover:bg-slate-50/80 dark:hover:bg-slate-700/30 transition-colors">
                  <td class="px-8 py-5">
                    <% if attendance.check_in.present? && attendance.check_out.blank? %>
                      <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                        <span class="font-bold text-emerald-600 dark:text-emerald-400">Working</span>
                      </div>
                    <% elsif attendance.check_in.present? && attendance.check_out.present? %>
                      <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-slate-300"></div>
                        <span class="font-bold text-slate-600 dark:text-slate-400">Completed</span>
                      </div>
                    <% else %>
                      <%# This case should not really happen with the new logic, but for safety: %>
                      <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-rose-500"></div>
                        <span class="font-bold text-rose-600 dark:text-rose-400">Partial</span>
                      </div>
                    <% end %>
                  </td>
                  <td class="px-8 py-5 text-sm font-medium text-slate-500 dark:text-slate-400">
                    <%= (attendance.check_in || attendance.check_out).strftime("%B %d, %Y") %>
                  </td>
                  <td class="px-8 py-5 text-sm font-black text-slate-900 dark:text-white">
                    <%= attendance.check_in&.strftime("%H:%M") || "-" %>
                  </td>
                  <td class="px-8 py-5 text-sm font-black text-slate-900 dark:text-white">
                    <%= attendance.check_out&.strftime("%H:%M") || "-" %>
                  </td>
                  <td class="px-8 py-5 text-sm font-medium text-slate-500 dark:text-slate-400">
                    <%= attendance.formatted_duration %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="px-8 py-12 text-center">
                  <div class="flex flex-col items-center">
                    <svg class="w-12 h-12 text-slate-200 dark:text-slate-700 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                    <p class="text-slate-400 font-medium">No activity recorded yet.</p>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.9; }
  }
  .animate-pulse-slow {
    animation: pulse-slow 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>
