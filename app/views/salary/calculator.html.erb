<div class="max-w-4xl mx-auto px-4 py-12" data-controller="salary-calculator">
  <!-- Header Section -->
  <div class="mb-12 text-center">
    <h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight mb-3 italic">Salary <span class="text-blue-600 dark:text-blue-400">Pro</span> Estimator</h1>
    <p class="text-slate-500 dark:text-slate-400 max-w-lg mx-auto">Calculate your take-home pay with precision including OT and tax deductions based on current rules.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <!-- Calculator Form -->
    <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] p-10 shadow-2xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-700 relative overflow-hidden group">
      <div class="absolute -right-20 -top-20 w-64 h-64 bg-blue-500/5 rounded-full blur-3xl group-hover:bg-blue-500/10 transition-colors"></div>
      
      <div class="space-y-8 relative">
        <!-- Base Salary Input -->
        <div class="space-y-3">
          <label class="block text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Base Salary</label>
          <div class="relative">
            <input 
              type="number" 
              id="base_salary" 
              value="<%= @default_salary %>"
              class="w-full bg-slate-50 dark:bg-slate-900 border-none rounded-2xl px-6 py-5 text-2xl font-black text-slate-900 dark:text-white focus:ring-4 focus:ring-blue-500/20 transition-all placeholder:text-slate-300 dark:placeholder:text-slate-700"
              placeholder="0.00"
            >
            <span class="absolute right-6 top-1/2 -translate-y-1/2 text-2xl font-black text-slate-300 dark:text-slate-700">฿</span>
          </div>
        </div>

        <!-- OT Hours Input -->
        <div class="space-y-3">
          <label class="block text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Overtime Hours</label>
          <div class="relative">
            <input 
              type="number" 
              id="ot_hours" 
              value="0"
              class="w-full bg-slate-50 dark:bg-slate-900 border-none rounded-2xl px-6 py-5 text-2xl font-black text-slate-900 dark:text-white focus:ring-4 focus:ring-blue-500/20 transition-all"
              placeholder="0"
            >
            <span class="absolute right-6 top-1/2 -translate-y-1/2 text-2xl font-black text-slate-300 dark:text-slate-700">HRS</span>
          </div>
        </div>

        <!-- Calculate Button -->
        <button 
          type="button"
          id="calculate_btn"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black py-4 rounded-2xl shadow-xl shadow-blue-500/20 active:scale-95 transition-all flex items-center justify-center gap-2 group/btn"
        >
          <span>Calculate Now</span>
          <svg class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
        </button>

        <!-- Tax Inclusion Toggle -->
        <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-900 rounded-2xl">
          <div>
            <div class="font-bold text-slate-900 dark:text-white">Tax Professional</div>
            <div class="text-xs text-slate-500">Apply tax logic to results</div>
          </div>
          <button id="tax_toggle" class="w-14 h-8 bg-blue-600 rounded-full relative transition-colors duration-300">
            <div class="absolute w-6 h-6 bg-white rounded-full top-1 left-1 translate-x-6 transition-transform duration-300 shadow-sm"></div>
          </button>
        </div>
      </div>
    </div>

    <!-- Results Card -->
    <div class="space-y-6">
      <div class="bg-gradient-to-br from-blue-600 to-indigo-700 dark:from-slate-900 dark:to-indigo-950 rounded-[2.5rem] p-10 text-white shadow-2xl relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-48 h-48 bg-white/10 rounded-full -mr-24 -mt-24 blur-3xl group-hover:bg-white/20 transition-colors"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-blue-400/10 rounded-full -ml-24 -mb-24 blur-3xl group-hover:bg-blue-400/20 transition-colors"></div>

        <div class="relative">
          <h3 class="text-indigo-200 font-bold uppercase tracking-widest text-xs mb-8">Estimated Net Salary</h3>
          <div class="text-6xl font-black mb-10 tracking-tighter" id="display_net_amount">0.00 ฿</div>
          
          <div class="space-y-4 pt-10 border-t border-white/10">
            <div class="flex justify-between items-center">
              <span class="text-indigo-200/60 font-bold text-sm">OT Payment</span>
              <span class="font-black text-indigo-100" id="display_ot_pay">+ 0.00 ฿</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-indigo-200/60 font-bold text-sm">Gross Income</span>
              <span class="font-black text-indigo-100" id="display_gross">0.00 ฿</span>
            </div>
            <div class="flex justify-between items-center text-rose-400">
              <span class="font-bold text-sm opacity-60">Tax (<span id="display_tax_pct">0</span>%)</span>
              <span class="font-black" id="display_tax_amount">- 0.00 ฿</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Formula Notice -->
      <div class="bg-blue-50 dark:bg-blue-900/20 rounded-2xl p-6 border border-blue-100 dark:border-blue-900/30">
        <div class="flex gap-4 items-start">
          <div class="text-blue-600 dark:text-blue-400">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div>
            <div class="font-bold text-blue-900 dark:text-blue-100 text-sm">Calculation Rule</div>
            <p class="text-xs text-blue-700/60 dark:text-blue-400/60 mt-1 leading-relaxed">OT is calculated at Hourly Rate × Hours. Tax is tiered: 0% up to 30k, 5% up to 50k, and 10% above 50k base salary.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const init = () => {
      const baseInput = document.getElementById('base_salary');
      const otInput = document.getElementById('ot_hours');
      const taxToggle = document.getElementById('tax_toggle');
      const netDisplay = document.getElementById('display_net_amount');
      const otDisplay = document.getElementById('display_ot_pay');
      const grossDisplay = document.getElementById('display_gross');
      const taxPctDisplay = document.getElementById('display_tax_pct');
      const taxAmtDisplay = document.getElementById('display_tax_amount');
      const calcBtn = document.getElementById('calculate_btn');

      if (!calcBtn) return; // Guard for non-calculator pages

      let isTaxEnabled = true;

      const formatCurrency = (amount) => {
        return new Intl.NumberFormat('th-TH', { 
          minimumFractionDigits: 2,
          maximumFractionDigits: 2 
        }).format(amount) + ' ฿';
      };

      const calculate = () => {
        netDisplay.classList.add('animate-pulse');
        setTimeout(() => netDisplay.classList.remove('animate-pulse'), 500);

        const baseSalary = parseFloat(baseInput.value) || 0;
        const otHours = parseFloat(otInput.value) || 0;

        const hourlyRate = baseSalary / 240.0;
        const otPay = otHours * hourlyRate;
        const grossIncome = baseSalary + otPay;

        // Tax Logic: Determined by Base Salary
        let taxPercentage = 0;
        if (isTaxEnabled) {
          if (baseSalary <= 30000) taxPercentage = 0;
          else if (baseSalary <= 50000) taxPercentage = 5;
          else taxPercentage = 10;
        }

        const taxAmount = (grossIncome * (taxPercentage / 100.0));
        const netAmount = grossIncome - taxAmount;

        netDisplay.textContent = formatCurrency(netAmount);
        otDisplay.textContent = '+ ' + formatCurrency(otPay);
        grossDisplay.textContent = formatCurrency(grossIncome);
        taxPctDisplay.textContent = taxPercentage;
        taxAmtDisplay.textContent = '- ' + formatCurrency(taxAmount);
      };

      calcBtn.addEventListener('click', calculate);
      
      taxToggle.addEventListener('click', () => {
        isTaxEnabled = !isTaxEnabled;
        const dot = taxToggle.querySelector('div');
        if (isTaxEnabled) {
          taxToggle.classList.remove('bg-slate-300', 'dark:bg-slate-700');
          taxToggle.classList.add('bg-blue-600');
          dot.classList.add('translate-x-6');
        } else {
          taxToggle.classList.remove('bg-blue-600');
          taxToggle.classList.add('bg-slate-300', 'dark:bg-slate-700');
          dot.classList.remove('translate-x-6');
        }
        calculate();
      });

      calculate();
    };

    document.addEventListener('turbo:load', init);
    // Fallback for direct load or non-turbo environments
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
