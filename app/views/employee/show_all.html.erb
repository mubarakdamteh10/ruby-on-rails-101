<div class="min-h-screen bg-slate-50 p-6">
  <div class="mx-auto max-w-6xl">
    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-2xl font-bold text-slate-900">All Employees</h1>
      <%= link_to "Create Employee", new_employee_path, class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
    </div>

    <% if notice.present? %>
      <div class="mb-4 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
        <%= notice %>
      </div>
    <% end %>

    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-100">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Employee ID</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Name</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Email</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Phone</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Address</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% @employees.each do |employee| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3 text-sm text-slate-800"><%= employee.employee_id %></td>
              <td class="px-4 py-3 text-sm text-slate-800"><%= employee.name %></td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= employee.email %></td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= employee.phone %></td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= employee.address %></td>
              <td class="px-4 py-3 text-sm">
                <div class="flex items-center gap-2">
                  <%= link_to "View", employee_path(employee), class: "rounded-md border border-slate-300 px-3 py-1.5 text-slate-700 hover:bg-slate-100" %>
                  <%= link_to "Edit", edit_employee_path(employee), class: "rounded-md border border-blue-300 px-3 py-1.5 text-blue-700 hover:bg-blue-50" %>
                  <%= button_to "Delete", employee_path(employee), method: :delete, class: "rounded-md border border-rose-300 px-3 py-1.5 text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "Delete this employee?" }, class: "inline-block" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
