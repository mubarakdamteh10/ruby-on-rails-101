<div class="min-h-screen p-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Employees</h1>
      <%= link_to "Create Employee", new_admin_employee_path, class: "rounded-lg bg-blue-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 shadow-lg shadow-blue-500/20 active:scale-95 transition-all" %>
    </div>


    <div class="bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead class="bg-slate-50/50 dark:bg-slate-900/40 border-b border-slate-200 dark:border-slate-700">
          <tr>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Employee ID</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Name</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Email</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Phone</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Address</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
          <% @employees.each do |employee| %>
            <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-700/30 transition-colors">
              <td class="px-6 py-5 text-sm font-medium text-slate-600 dark:text-slate-400"><%= employee.employee_id %></td>
              <td class="px-6 py-5 text-sm font-bold text-slate-900 dark:text-white"><%= employee.name %></td>
              <td class="px-6 py-5 text-sm text-slate-600 dark:text-slate-400"><%= employee.email %></td>
              <td class="px-6 py-5 text-sm text-slate-600 dark:text-slate-400"><%= employee.phone %></td>
              <td class="px-6 py-5 text-sm text-slate-600 dark:text-slate-400 text-xs max-w-xs truncate"><%= employee.address %></td>
              <td class="px-6 py-5 text-right">
                <div class="flex items-center justify-end gap-3 text-xs">
                  <%= link_to "View", admin_employee_path(employee), class: "text-blue-600 dark:text-blue-400 hover:underline font-bold" %>
                  <%= link_to "Edit", edit_admin_employee_path(employee), class: "text-amber-600 dark:text-amber-400 hover:underline font-bold" %>
                  <%= button_to "Delete", admin_employee_path(employee), method: :delete, form: { data: { turbo_confirm: "Delete this employee?" }, class: "inline" }, class: "text-rose-600 dark:text-rose-400 hover:underline font-bold bg-transparent border-none p-0 cursor-pointer" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
