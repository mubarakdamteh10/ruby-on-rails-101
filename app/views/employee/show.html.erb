<div class="mx-auto max-w-2xl mt-12 p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Employee Detail</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-slate-700 dark:text-slate-300">
    <p><strong class="text-slate-900 dark:text-white">Employee ID:</strong> <%= @employee.employee_id %></p>
    <p><strong class="text-slate-900 dark:text-white">Code:</strong> <%= @employee.code %></p>
    <p><strong class="text-slate-900 dark:text-white">Name:</strong> <%= @employee.name %></p>
    <p><strong class="text-slate-900 dark:text-white">Email:</strong> <%= @employee.email %></p>
    <p><strong class="text-slate-900 dark:text-white">Phone:</strong> <%= @employee.phone %></p>
    <p><strong class="text-slate-900 dark:text-white">Department:</strong> <%= @employee.department %></p>
    <p><strong class="text-slate-900 dark:text-white">Position:</strong> <%= @employee.position %></p>
    <p><strong class="text-slate-900 dark:text-white">Salary:</strong> <%= number_to_currency(@employee.salary) %></p>
    <p><strong class="text-slate-900 dark:text-white">Is Taxed:</strong> <%= @employee.is_tax ? 'Yes' : 'No' %></p>
    <p class="md:col-span-2"><strong class="text-slate-900 dark:text-white">Address:</strong> <%= @employee.address %></p>
  </div>

  <div class="mt-8">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Attendance History</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
        <thead class="bg-slate-50 dark:bg-slate-900/50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-semibold text-slate-600 dark:text-slate-400">Check In</th>
            <th class="px-4 py-2 text-left text-xs font-semibold text-slate-600 dark:text-slate-400">Check Out</th>
            <th class="px-4 py-2 text-left text-xs font-semibold text-slate-600 dark:text-slate-400">OT (Hours)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
          <% @employee.attendances.order(check_in: :desc).each do |attendance| %>
            <tr>
              <td class="px-4 py-2 text-sm text-slate-700 dark:text-slate-300"><%= attendance.check_in&.strftime("%Y-%m-%d %H:%M") %></td>
              <td class="px-4 py-2 text-sm text-slate-700 dark:text-slate-300"><%= attendance.check_out&.strftime("%Y-%m-%d %H:%M") %></td>
              <td class="px-4 py-2 text-sm text-slate-700 dark:text-slate-300"><%= attendance.over_time_hour %></td>
            </tr>
          <% end %>
          <% if @employee.attendances.empty? %>
            <tr>
              <td colspan="3" class="px-4 py-4 text-sm text-center text-slate-500">No attendance records found.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-8 flex gap-4">
    <%= link_to "Edit", edit_employee_path(@employee), class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition" %>
    <%= link_to "Back to Employees", root_path, class: "rounded-md border border-slate-300 dark:border-slate-600 px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition" %>
  </div>
</div>
